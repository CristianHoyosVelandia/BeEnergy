# Environment Configuration - BeEnergy Microservices
# Copia este archivo a .env y ajusta las URLs según tu entorno.

# ==================== OPCIÓN 1: API GATEWAY ====================
# Si usas un único gateway que enruta a todos los servicios:
# GATEWAY_URL=https://api.beenergy.com

# ==================== OPCIÓN 2: MICROSERVICIOS DIRECTOS ====================
# Desarrollo local: cada microservicio en su puerto.
# En emulador Android usa 10.0.2.2 en lugar de localhost (ej: http://10.0.2.2:8000).
AUTH_SERVICE_URL=http://localhost:8000
USER_SERVICE_URL=http://localhost:8001
CREDITS_SERVICE_URL=http://localhost:8002
TRADING_SERVICE_URL=http://localhost:8003
MONITORING_SERVICE_URL=http://localhost:8004
AUDIT_SERVICE_URL=http://localhost:8005

# Empresas (Kupi) - externo
EMPRESAS_SERVICE_URL=https://kupi.com.co/ws

# Fallback cuando no hay GATEWAY_URL ni URL por servicio
BASE_URL=http://localhost:8000

# App
APP_CODE=0
APP_VERSION=6.5.5
DEFAULT_CITY_CODE=4110
